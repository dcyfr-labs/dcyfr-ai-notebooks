{
  "name": "@dcyfr/ai-notebooks",
  "private": true,
  "version": "1.0.1",
  "description": "Data science notebook toolkit with TypeScript tooling for Jupyter notebook management, data pipelines, and visualization",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./notebook": "./src/notebook/index.ts",
    "./pipeline": "./src/pipeline/index.ts",
    "./visualization": "./src/visualization/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "example:explore": "tsx examples/data-exploration/index.ts",
    "example:pipeline": "tsx examples/data-pipeline/index.ts",
    "example:analysis": "tsx examples/model-analysis/index.ts"
  },
  "keywords": [
    "dcyfr",
    "ai",
    "jupyter",
    "notebooks",
    "data-science",
    "data-pipeline",
    "visualization",
    "typescript"
  ],
  "author": "DCYFR Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-notebooks"
  },
  "bugs": {
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-notebooks/issues"
  },
  "homepage": "https://github.com/dcyfr-labs/dcyfr-ai-notebooks#readme",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
